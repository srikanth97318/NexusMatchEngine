# General App Settings
ENVIRONMENT=development
PROJECT_NAME="NexusMatch Engine"

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexusmatch

# Qdrant Vector DB
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis & Celery
REDIS_URL=redis://localhost:6379/0

# LLM Providers (vLLM or OpenAI)
VLLM_API_URL=http://localhost:8000/v1
VLLM_API_KEY=mock-key-for-local-vllm
OPENAI_API_KEY=your-openai-api-key-here
